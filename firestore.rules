rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: businesses
    // Fields:
    //   - name_en: string (required)
    //   - name_ar: string
    //   - name_ku: string
    //   - city: string (required)
    //   - category: string
    //   - phone: string
    //   - address: string
    //   - status: string (enum: ["pending", "approved", "rejected"])
    //   - confidence_score: number
    //   - created_at: string (ISO 8601)
    //
    // Collection: raw_businesses
    // Fields: [Same as businesses]
    //
    // Collection: agent_tasks
    // Fields:
    //   - type: string
    //   - instruction: string
    //   - cities: list
    //   - status: string
    //   - created_at: string
    //
    // Collection: agent_logs
    // Fields:
    //   - timestamp: string
    //   - message: string
    //   - type: string
    //   - record_id: string
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "mahdialmuntadhar1@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidBusiness(data) {
      return data.keys().hasAll(['name_en', 'city']) &&
             data.name_en is string && data.name_en.size() > 0 &&
             data.city is string && data.city.size() > 0;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['type', 'instruction', 'status']) &&
             data.type is string &&
             data.instruction is string &&
             data.status is string;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['timestamp', 'message', 'type']) &&
             data.message is string &&
             data.type is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /businesses/{businessId} {
      // Home page needs to read approved businesses
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /raw_businesses/{businessId} {
      allow read, write: if isAdmin();
    }

    match /agent_tasks/{taskId} {
      allow read, write: if isAdmin();
    }

    match /agent_logs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
